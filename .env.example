# ===================================================================
# vdkify server config — copy this file to env/.env and edit.
# env/.env and the data/ directory are gitignored.
# Real environment variables override these values.
# ===================================================================

# port the server listens on
PORT=4400

# Base domain for free site domains: every site is served at
# <name>.<BASE_DOMAIN>:<PORT>. "localhost" works with ZERO setup in
# modern browsers (*.localhost resolves to 127.0.0.1 automatically).
# On a LAN or with a real wildcard domain, set it here, e.g.:
#   BASE_DOMAIN=vdk.lan        (with dnsmasq: address=/.vdk.lan/192.168.1.20)
#   BASE_DOMAIN=sites.vdkgroup.com   (with a wildcard DNS record)
BASE_DOMAIN=localhost

# How site URLs are DISPLAYED (set these when running behind a reverse
# proxy / Cloudflare Tunnel where the public scheme/port differ from the
# local listener — e.g. PUBLIC_SCHEME=https and PUBLIC_PORT=443):
PUBLIC_SCHEME=http
#PUBLIC_PORT=443

# where deployed sites + the database live
DATA_DIR=data
DB_PATH=data/vdkify.db

# dashboard sign-in lifetime (hours)
SESSION_HOURS=168

# upload / repo-download size cap (MB)
MAX_DEPLOY_MB=200

# how many old deploys to keep per site (for rollback)
KEEP_DEPLOYS=10
